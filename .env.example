GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro-latest
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
PORT=3000

# /api/chat-diet: przy ustawionym SUPABASE_URL + SUPABASE_ANON_KEY wymagany jest JWT (zalogowany użytkownik).
# CHAT_REQUIRE_AUTH=false — wyłącza JWT (tylko dev / świadomy ryzyko).
# CHAT_RATE_MAX=30 i CHAT_RATE_WINDOW_MS=60000 — limit zapytań na użytkownika/IP w oknie.
